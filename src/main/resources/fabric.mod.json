{
  "schemaVersion": 1,
  "id": "copycoords",
  "version": "${version}",
  "name": "CopyCoords",
  "description": "CopyCoords is a client-side Fabric mod that makes coordinates faster to copy, convert, and share.",
  "authors": ["freddy._.fazbear (Discord)","MR-Kartoshki (GitHub)"],
  "license": "AGPL-3.0-only",
  "icon": "assets/copycoords/icon.png",
  "contact": {
    "issues": "https://github.com/MR-kartoshki/copycoords/issues",
    "homepage": "https://github.com/MR-kartoshki/copycoords"
  },
  "environment": "client",
  "entrypoints": {
    "client": ["com.example.copycoords.CopyCoords"],
    "modmenu": ["com.example.copycoords.CopyCoordsModMenuIntegration"]
  },
  "depends": {
    "java": ">=17",
    "fabricloader": "*",
    "minecraft": "${mcversion}",
    "fabric-api": "*",
    "cloth-config": "*",
    "modmenu": "*"
  },
  "suggests": {}
}
